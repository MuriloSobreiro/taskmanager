// firestore.rules
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Lê /users/{uid} server-side para verificar approved/admin.
    // Cacheado dentro da mesma avaliação de regra.
    function userData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isApproved() {
      return isSignedIn()
          && userData(request.auth.uid).get('approved', false) == true;
    }

    function isAdmin() {
      return isSignedIn()
          && userData(request.auth.uid).get('admin', false) == true;
    }

    function isOwner(uid) {
      return isApproved() && request.auth.uid == uid;
    }

    function validBucket() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'accentIndex', 'tasks', 'createdAt'])
          && d.name is string
          && d.name.size() > 0
          && d.name.size() <= 100
          && d.accentIndex is int
          && d.accentIndex >= 0
          && d.accentIndex < 8
          && d.tasks is list
          && d.tasks.size() <= 500;
    }

    // ── /users/{uid} ─────────────────────────────────────────
    match /users/{uid} {

      // Lê o próprio perfil (durante o boot para verificar approved/admin)
      // ou admin lê qualquer perfil
      allow read: if request.auth.uid == uid || isAdmin();

      // Criação durante o signup:
      // O app cria o documento com approved=false e admin=false.
      // Qualquer usuário autenticado pode criar o próprio documento
      // desde que comece com approved=false e admin=false.
      allow create: if request.auth.uid == uid
          && request.resource.data.get('approved', false) == false
          && request.resource.data.get('admin',    false) == false;

      // Atualização do próprio documento (dois casos):
      allow update: if request.auth.uid == uid
          // 1. Jamais permite auto-promoção para admin
          && request.resource.data.get('admin', false)
             == resource.data.get('admin', false)
          && (
              // Caso A: não está mudando "approved" — atualização normal
              request.resource.data.approved == resource.data.approved
              ||
              // Caso B: setando approved=true pela primeira vez
              // Valida que o código de convite foi de fato consumido por este uid
              (
                request.resource.data.approved == true
                && resource.data.approved       == false
                && request.resource.data.keys().hasAll(['inviteCode'])
                && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode))
                     .data.usedBy == uid
                && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode))
                     .data.used   == true
              )
          );

      // Admin promove outro usuário (não a si mesmo)
      // Apenas os campos de promoção podem ser alterados nesta operação
      allow update: if isAdmin()
          && request.auth.uid != uid
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['admin', 'promotedBy', 'promotedAt']);

      allow delete: if false;

      // ── /users/{uid}/buckets/{bucketId} ────────────────────
      match /buckets/{bucketId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid) && validBucket();
        allow update: if isOwner(uid) && validBucket();
        allow delete: if isOwner(uid);
      }
    }

    // ── /inviteCodes/{code} ──────────────────────────────────
    match /inviteCodes/{code} {

      // Qualquer autenticado pode GET um código pelo ID exato
      // (necessário durante a transação do signup)
      // Ninguém sem ser admin pode LISTAR
      allow get:  if isSignedIn();
      allow list: if isAdmin();

      // Apenas admins criam novos códigos
      allow create: if isAdmin()
          && request.resource.data.used == false
          && request.resource.data.keys().hasAll(['used', 'createdBy', 'createdAt', 'expiresAt']);

      // Qualquer autenticado pode "consumir" um código não-usado:
      // — só pode marcar used=true
      // — usedBy deve ser o próprio uid
      // — apenas os campos de consumo podem ser alterados
      allow update: if isSignedIn()
          && resource.data.used               == false
          && request.resource.data.used       == true
          && request.resource.data.usedBy     == request.auth.uid
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['used', 'usedBy', 'usedAt']);

      // Admins podem revogar (deletar) códigos não utilizados
      allow delete: if isAdmin();
    }

    // ── Tudo mais: negar ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
