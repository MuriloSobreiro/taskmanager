// firestore.rules
// Plano Spark compatível — sem Cloud Functions
//
// Como a segurança funciona sem custom claims:
//   Cada operação de leitura/escrita consulta /users/{uid} via get()
//   para verificar os campos "approved" e "admin" server-side.
//   O front-end não tem como falsificar esses campos — a regra
//   é avaliada pelo Firestore, não pelo browser.
//
// Trade-off: cada operação em /buckets consome 1 Firestore read extra
// para o get() do usuário. No plano Spark (50k reads/dia) isso é
// suficiente para equipes pequenas e médias.
//
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Lê o documento do usuário para obter approved/admin.
    // O resultado é cacheado dentro da mesma avaliação de regra.
    function userData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // Usuário autenticado + campo approved == true no Firestore
    function isApproved() {
      return isSignedIn()
          && userData(request.auth.uid).get('approved', false) == true;
    }

    // Usuário autenticado + campo admin == true no Firestore
    function isAdmin() {
      return isSignedIn()
          && userData(request.auth.uid).get('admin', false) == true;
    }

    // Aprovado E dono do path
    function isOwner(uid) {
      return isApproved() && request.auth.uid == uid;
    }

    // Valida estrutura de um bucket (evita writes malformados)
    function validBucket() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'accentIndex', 'tasks', 'createdAt'])
          && d.name is string
          && d.name.size() > 0
          && d.name.size() <= 100
          && d.accentIndex is int
          && d.accentIndex >= 0
          && d.accentIndex < 8
          && d.tasks is list
          && d.tasks.size() <= 500;
    }

    // ── /users/{uid} ─────────────────────────────────────────
    match /users/{uid} {

      // Usuário lê o próprio doc (para checar approved/admin no boot)
      // ou admin lê doc de qualquer usuário
      allow read: if request.auth.uid == uid || isAdmin();

      // Criação do próprio perfil durante o signup:
      // começa como não-aprovado e não-admin — o app não pode criar admin diretamente
      allow create: if request.auth.uid == uid
          && request.resource.data.keys().hasAll(['approved', 'admin', 'createdAt'])
          && request.resource.data.approved == false
          && request.resource.data.admin    == false;

      // O usuário pode atualizar o próprio doc com duas condições:
      //   a) campo "admin" não pode ser alterado pelo próprio usuário
      //   b) para setar approved=true, o código de convite deve ter sido
      //      realmente consumido por este uid (verificação cross-doc via get())
      allow update: if request.auth.uid == uid
          // Nunca auto-promover para admin
          && request.resource.data.get('admin', false)
             == resource.data.get('admin', false)
          && (
            // Nenhuma mudança em approved → atualização normal de outros campos
            request.resource.data.approved == resource.data.approved
            ||
            // Setando approved=true pela primeira vez: valida o código
            (
              request.resource.data.approved == true
              && resource.data.approved      == false
              && request.resource.data.keys().hasAll(['inviteCode'])
              // O código referenciado deve ter sido marcado como usado por este uid
              && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode))
                   .data.usedBy == uid
              && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCode))
                   .data.used   == true
            )
          );

      // Um admin pode promover/rebaixar outro usuário (mas não a si mesmo)
      // Apenas os campos de promoção podem ser tocados nessa operação
      allow update: if isAdmin()
          && request.auth.uid != uid
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['admin', 'promotedBy', 'promotedAt']);

      // Ninguém exclui o próprio perfil pelo app
      allow delete: if false;

      // ── /users/{uid}/buckets/{bucketId} ────────────────────
      match /buckets/{bucketId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid) && validBucket();
        allow update: if isOwner(uid) && validBucket();
        allow delete: if isOwner(uid);
      }
    }

    // ── /inviteCodes/{code} ──────────────────────────────────
    match /inviteCodes/{code} {

      // Qualquer usuário autenticado pode GET um código específico pelo ID
      // (necessário para validar antes de reivindicar)
      // Ninguém pode LISTAR (sem list access, enumerar é inviável)
      allow get:  if isSignedIn();
      allow list: if isAdmin();

      // Apenas admins criam novos códigos (direto do painel, sem Functions)
      allow create: if isAdmin()
          && request.resource.data.used == false
          && request.resource.data.keys().hasAll(['used', 'createdBy', 'createdAt', 'expiresAt']);

      // Qualquer usuário autenticado pode "reivindicar" um código não-usado
      // Só pode marcar como used=true, e usedBy deve ser o próprio uid
      // Apenas os 3 campos de consumo podem ser alterados
      allow update: if isSignedIn()
          && resource.data.used               == false
          && request.resource.data.used       == true
          && request.resource.data.usedBy     == request.auth.uid
          && request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasOnly(['used', 'usedBy', 'usedAt']);

      // Admins podem excluir códigos (ex: expirados, não utilizados)
      allow delete: if isAdmin();
    }

    // ── Tudo mais: negar ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
